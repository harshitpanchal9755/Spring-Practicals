<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	
	<bean id="payment" class="com.rays.icon.Payment">
	<property name="balance" value="50000"></property>
	</bean>
	
	<bean id="inventary" class="com.rays.icon.Inventary">
	<property name="book" value="15"></property>
	</bean>
	
	<bean id="order" class="com.rays.icon.Order">
	<property name="inventary" ref="inventary"></property>
	<property name="payment" ref="payment"></property>
	</bean>

	</beans>